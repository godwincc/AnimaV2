{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  // ConnectionStrings:Default and Jwt:SigningKey are deliberately NOT set here -- they're secrets
  // and must never be checked in. Program.cs fails fast with a clear error if either is missing.
  // Local dev (non-Docker): dotnet user-secrets set "ConnectionStrings:Default" "..."
  //                         dotnet user-secrets set "Jwt:SigningKey" "..."
  //                         (one-time setup; see README-dev-secrets.md)
  // Docker/deployment: supplied via env vars ConnectionStrings__Default / Jwt__SigningKey
  //                    (see deployment/docker-compose.yaml and deployment/.env.example)
  "Jwt": {
    "Issuer": "AnimaServer",
    "Audience": "AnimaClient",
    "LifetimeDays": 180
  }
}
